'use client'

/**
 * CopilotBox — News Copilot con Perplexity Sonar
 * Componente reutilizable en /al-dia, /noticias, /mercados
 */

import { useState } from 'react'

interface CopilotBoxProps {
  context?: 'noticias' | 'mercados' | 'crypto' | 'divisas' | 'general'
  placeholder?: string
  suggestions?: string[]
}

interface CopilotResponse {
  answer: string
  sources: string[]
  tier_limited: boolean
  model: string
  error?: string
}

const DEFAULT_SUGGESTIONS: Record<string, string[]> = {
  noticias: [
    '¿Cómo afecta el acuerdo con el FMI al dólar?',
    '¿Qué implica el fallo de YPF para los inversores?',
    'Explicame la inflación de este mes en términos simples',
    '¿Qué está pasando con el riesgo país?',
  ],
  mercados: [
    '¿Por qué subió el MERVAL hoy?',
    '¿Vale la pena comprar CEDEARs de bancos argentinos?',
    'Comparame GGAL vs BMA',
    '¿Cómo está el sector energético en BYMA?',
  ],
  crypto: [
    '¿Por qué Bitcoin está en estos niveles?',
    '¿Tiene sentido dolarizarse con USDT en Argentina?',
    'Explicame el halving y su impacto en el precio',
    '¿Qué diferencia hay entre MEP y crypto dólar?',
  ],
  divisas: [
    '¿Cuál es la brecha cambiaria actual?',
    'Explicame la diferencia entre MEP y CCL',
    '¿Conviene viajar con tarjeta o llevar efectivo?',
    '¿Qué es el dólar blend?',
  ],
  general: [
    '¿Cómo está la economía argentina hoy?',
    '¿Qué son los CEDEARs y cómo funcionan?',
    '¿Conviene invertir en plazo fijo o dólar?',
    'Explicame el carry trade en Argentina',
  ],
}

export default function CopilotBox({
  context = 'general',
  placeholder = '¿Qué querés saber sobre los mercados hoy?',
  suggestions,
}: CopilotBoxProps) {
  const [query, setQuery] = useState('')
  const [loading, setLoading] = useState(false)
  const [result, setResult] = useState<CopilotResponse | null>(null)

  const pills = suggestions ?? DEFAULT_SUGGESTIONS[context] ?? DEFAULT_SUGGESTIONS.general

  async function handleSubmit(q: string) {
    const finalQuery = q.trim()
    if (!finalQuery || loading) return

    setLoading(true)
    setResult(null)

    try {
      const res = await fetch('/api/copilot', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: finalQuery, context }),
      })
      const data: CopilotResponse = await res.json()
      setResult(data)
    } catch {
      setResult({ answer: '', sources: [], tier_limited: false, model: '', error: 'Error de conexión. Intentá de nuevo.' })
    } finally {
      setLoading(false)
    }
  }

  return (
    <div className="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden">
      {/* Header */}
      <div className="px-5 py-4 border-b border-zinc-800 flex items-center gap-3">
        <div className="w-7 h-7 rounded-lg bg-gradient-to-br from-blue-500 to-violet-600 flex items-center justify-center text-sm">
          ✦
        </div>
        <div>
          <span className="text-sm font-semibold text-zinc-100">Copiloto Financiero</span>
          <span className="ml-2 text-xs bg-blue-500/20 text-blue-400 border border-blue-500/30 px-2 py-0.5 rounded-full">
            Perplexity Sonar
          </span>
        </div>
      </div>

      {/* Input */}
      <div className="p-4">
        <div className="flex gap-2">
          <input
            type="text"
            value={query}
            onChange={e => setQuery(e.target.value)}
            onKeyDown={e => e.key === 'Enter' && handleSubmit(query)}
            placeholder={placeholder}
            disabled={loading}
            className="flex-1 bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-blue-500 transition-colors disabled:opacity-50"
          />
          <button
            onClick={() => handleSubmit(query)}
            disabled={loading || !query.trim()}
            className="bg-blue-600 hover:bg-blue-500 disabled:bg-zinc-700 disabled:cursor-not-allowed text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors whitespace-nowrap"
          >
            {loading ? (
              <span className="flex items-center gap-2">
                <svg className="animate-spin w-4 h-4" viewBox="0 0 24 24" fill="none">
                  <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"/>
                  <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
                Buscando
              </span>
            ) : 'Preguntar'}
          </button>
        </div>

        {/* Pills de sugerencias */}
        {!result && (
          <div className="flex flex-wrap gap-2 mt-3">
            {pills.map(pill => (
              <button
                key={pill}
                onClick={() => { setQuery(pill); handleSubmit(pill) }}
                disabled={loading}
                className="text-xs bg-zinc-800 hover:bg-zinc-700 text-zinc-400 hover:text-zinc-200 px-3 py-1.5 rounded-lg transition-colors disabled:opacity-50"
              >
                {pill}
              </button>
            ))}
          </div>
        )}
      </div>

      {/* Resultado */}
      {result && (
        <div className="border-t border-zinc-800">
          {result.error ? (
            <div className="px-5 py-4 text-sm text-red-400">{result.error}</div>
          ) : (
            <div className="px-5 py-4 space-y-4">
              {/* Respuesta */}
              <div className="text-sm text-zinc-200 leading-relaxed whitespace-pre-wrap">
                {result.answer}
              </div>

              {/* Fuentes (solo Pro) */}
              {result.sources.length > 0 && (
                <div>
                  <div className="text-xs text-zinc-500 mb-2 font-medium uppercase tracking-wider">Fuentes</div>
                  <div className="space-y-1">
                    {result.sources.map((src, i) => (
                      <a
                        key={i}
                        href={src}
                        target="_blank"
                        rel="noopener noreferrer"
                        className="block text-xs text-blue-400 hover:text-blue-300 truncate transition-colors"
                      >
                        {src}
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {/* CTA para tier limitado */}
              {result.tier_limited && (
                <div className="bg-gradient-to-r from-blue-950/50 to-violet-950/50 border border-blue-800/30 rounded-xl p-3 flex items-center justify-between">
                  <div>
                    <div className="text-xs font-semibold text-blue-300">Respuesta limitada</div>
                    <div className="text-xs text-zinc-400 mt-0.5">IN Pro incluye análisis profundo + fuentes verificadas</div>
                  </div>
                  <a
                    href="/planes"
                    className="text-xs bg-blue-600 hover:bg-blue-500 text-white px-3 py-1.5 rounded-lg font-semibold transition-colors whitespace-nowrap"
                  >
                    Mejorar plan →
                  </a>
                </div>
              )}

              {/* Footer: nueva pregunta */}
              <button
                onClick={() => { setResult(null); setQuery('') }}
                className="text-xs text-zinc-500 hover:text-zinc-300 transition-colors"
              >
                ← Nueva pregunta
              </button>
            </div>
          )}
        </div>
      )}

      {/* Footer disclaimer */}
      <div className="px-5 py-3 border-t border-zinc-800/50 text-xs text-zinc-600">
        El Copiloto usa IA con búsqueda web en tiempo real. No es asesoramiento financiero.
      </div>
    </div>
  )
}
